# Copy to .env for local dev. On Railway set these in the dashboard.

# Zoho URL that returns the file. Use {{id}} where the document id should go.
# Example: https://creator.zoho.com/api/v2/your_org/report/Download_Report?id={{id}}
ZOHO_FILE_URL=https://creator.zoho.com/api/.../report/...?id={{id}}

# Optional: if your Zoho API requires auth
# ZOHO_ACCESS_TOKEN=your_zoho_oauth_token

# Railway sets PORT automatically
# PORT=3000
